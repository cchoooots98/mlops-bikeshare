PGHOST=localhost
PGPORT=15432
PGDATABASE=velib_dw
PGUSER=velib
PGPASSWORD=velib
OPENWEATHER_API_KEY=replace-me

# Optional for local workstation profile-based auth.
# Local Docker Compose adds AWS profile mounts via docker-compose.local.yml.
# On EC2, rely on the instance profile and leave AWS_PROFILE unset.
AWS_SDK_LOAD_CONFIG=1

AWS_REGION=eu-west-3
BUCKET=bikeshare-paris-387706002632-eu-west-3
CITY=paris
TRAIN_PG_SCHEMA=analytics
TRAIN_FEATURE_TABLE=feat_station_snapshot_5min
ONLINE_FEATURE_TABLE=feat_station_snapshot_latest

MLFLOW_TRACKING_URI=sqlite:///model_dir/mlflow.db
MLFLOW_EXPERIMENT_NAME=bikeshare-local
PREDICT_BIKES=true
TARGET_NAME=bikes
SERVING_ENVIRONMENT=local

